# Environment Configuration Template
# Copy this file to .env and fill in the values

# ======================
# Application Settings
# ======================
NODE_ENV="production"
PORT="3000"
HOSTNAME="0.0.0.0"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ======================
# Database (PostgreSQL)
# ======================
# Production database connection
DATABASE_URL="postgresql://username:password@localhost:5432/skycybernet?schema=public&connection_limit=10&pool_timeout=20"

# Direct database connection (for migrations)
DATABASE_DIRECT_URL="postgresql://username:password@localhost:5432/skycybernet?schema=public"

# For Docker Compose
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-secure-password-here"
POSTGRES_DB="skycybernet"
POSTGRES_PORT="5432"

# For development (SQLite - not recommended for production)
# DATABASE_URL="file:./prisma/dev.db"

# ======================
# Redis
# ======================
REDIS_URL="redis://localhost:6379"
REDIS_PORT="6379"

# ======================
# Security
# ======================
# Generate with: openssl rand -base64 32
COOKIE_SECRET="your-cookie-secret-min-32-chars-long-generate-strong-random-string"

# CORS allowed origins (comma-separated)
CORS_ORIGIN="https://your-domain.com,https://www.your-domain.com"

# ======================
# Rate Limiting
# ======================
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="60000"

# ======================
# Media Upload
# ======================
# Max file size in bytes (default: 10MB)
MAX_FILE_SIZE="10485760"

# Max files per post
MAX_FILES_PER_POST="4"

# Allowed file types (comma-separated MIME types)
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp,image/gif"
ALLOWED_VIDEO_TYPES="video/mp4,video/webm,video/quicktime"

# ======================
# Monitoring (Optional)
# ======================
# Sentry DSN for error tracking
# SENTRY_DSN="https://your-sentry-dsn"

# Application version
# npm_package_version="1.0.0"

# ======================
# Development Only
# ======================
# Enable debug logging
# DEBUG="true"

# ======================
# Production Checklist
# ======================
# [ ] Set NODE_ENV to 'production'
# [ ] Generate strong COOKIE_SECRET
# [ ] Configure production DATABASE_URL
# [ ] Set correct NEXT_PUBLIC_APP_URL
# [ ] Configure CORS_ORIGIN
# [ ] Set secure POSTGRES_PASSWORD
# [ ] Review rate limits
# [ ] Configure error tracking (Sentry)
# [ ] Enable HTTPS/SSL
# [ ] Set up backups for database
# [ ] Configure monitoring and alerts
